# =============================================================
# SIG – Sistema de Impuestos a las Ganancias
# Variables de entorno requeridas
# Copiá este archivo como .env y completá los valores reales.
# NUNCA commitees el archivo .env
# =============================================================

# ------------------------------------------------------------
# URL base del backend Spring Boot
# Usado SOLO en rutas server-side (API Routes de Next.js).
# No debe estar expuesto en el bundle del cliente.
# ------------------------------------------------------------
API_BASE_URL=http://localhost:8080

# ------------------------------------------------------------
# URL del backend expuesta al browser (solo para los dos
# componentes cliente que llaman al backend directamente:
# UploadXML y PeriodoActualEditable).
# En producción puede ser la misma que API_BASE_URL.
# ------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# ------------------------------------------------------------
# Seguridad de cookies
# Poner "true" en producción (requiere HTTPS).
# Dejar "false" en desarrollo local.
# ------------------------------------------------------------
COOKIE_SECURE=false
